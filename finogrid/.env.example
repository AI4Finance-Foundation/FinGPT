# ── Bridge API ─────────────────────────────────────────────────────────────────
BRIDGE_API_KEY=your_bridge_api_key_here
BRIDGE_API_URL=https://api.bridge.xyz/v0

# ── KYT / AML Provider ────────────────────────────────────────────────────────
KYT_API_KEY=your_kyt_api_key_here
KYT_API_URL=https://api.chainalysis.com

# ── Identity / KYB Provider ───────────────────────────────────────────────────
KYB_API_KEY=your_kyb_api_key_here
KYB_API_URL=https://api.identity-provider.com

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://finogrid:password@localhost:5432/finogrid
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
PUBSUB_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=finogrid_analytics

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your_jwt_secret_key_change_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── FinGPT / AI (agents only — NOT in hot path) ───────────────────────────────
# LLM provider for sentiment analysis and agent clients: "openai" | "minimax" | "fingpt"
FINGPT_LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
MINIMAX_API_KEY=your_minimax_api_key_here
HUGGINGFACE_TOKEN=your_huggingface_token_here
FINGPT_MODEL_PATH=FinGPT/fingpt-sentiment_llama2-13b_lora
FINGPT_FORECASTER_MODEL=FinGPT/fingpt-forecaster_dow30_llama2-7b_lora
FINNHUB_API_KEY=your_finnhub_api_key_here

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── Compliance ────────────────────────────────────────────────────────────────
KYT_RISK_THRESHOLD=7
SANCTIONS_SCREEN_ENABLED=true
TRAVEL_RULE_ENABLED=false
